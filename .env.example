# Copy to `.env` or `.env.local` for local development (never commit secrets).

# `local` (default) = in-memory notes, no Supabase required
# `production` = Supabase Auth + Postgres when URL/key are set
VITE_APP_MODE=local

# Supabase project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: canonical public URL (no trailing slash). Used for email confirmation redirects.
# Set in production so verification links point at your deployed domain, not localhost.
# VITE_SITE_URL=https://your-app.example.com

# OCR.space API key for the `ocr-image-to-text` Edge Function only. Do not prefix with VITE_ (never expose to the browser).
# Set in Supabase: Dashboard → Edge Functions → ocr-image-to-text → Secrets, or: `npx supabase secrets set OCR_SPACE_API_KEY=your_key`
# OCR_SPACE_API_KEY=
